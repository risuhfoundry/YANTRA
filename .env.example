# Python AI microservice used by the Next.js Yantra chat route.
# Set YANTRA_AI_TARGET to "local" for local FastAPI or "render" for the deployed service.
YANTRA_AI_TARGET="local"
YANTRA_AI_LOCAL_URL="http://127.0.0.1:8000"
YANTRA_AI_RENDER_URL="https://YOUR-YANTRA-AI-SERVICE.onrender.com"
# Backward-compatible alias for older setups.
YANTRA_AI_SERVICE_URL="https://YOUR-YANTRA-AI-SERVICE.onrender.com"
YANTRA_AI_SERVICE_TIMEOUT_MS="65000"

# Gemini API key used by the docs support route and as a fallback when the AI service URL is not set.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Supabase project settings for auth + persisted student profiles.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Sarvam room-side Yantra voice assistant.
SARVAM_API_KEY="YOUR_SARVAM_API_KEY"
YANTRA_SARVAM_STT_MODEL="saaras:v3"
YANTRA_SARVAM_STT_LANGUAGE="unknown"
YANTRA_SARVAM_STT_MODE="translate"
YANTRA_SARVAM_TTS_MODEL="bulbul:v3"
YANTRA_SARVAM_TTS_SPEAKER="anand"
YANTRA_SARVAM_TTS_LANGUAGE="en-IN"
YANTRA_SARVAM_TTS_PACE="0.94"

# Anthropic API Key: Used for Claude models (3.5 Sonnet/Opus).
# Required for high-complexity reasoning in the Orchestrator.
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY= 'YOUR_ANTHROPIC_API_KEY'

# Serper API Key: A fast Google Search API.
# Allows the AI to search the live web for real-time data/documentation.
# Get a key at: https://serper.dev/
SERPER_API_KEY= 'YOUR_SERPER_API_KEY'

# Prototype editor execution UI.
NEXT_PUBLIC_USE_MOCK_API="true"
