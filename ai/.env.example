YANTRA_KNOWLEDGE_DIR=knowledge
YANTRA_CHAT_PROVIDER=ring
YANTRA_COPILOT_MODEL=gpt-5-mini
YANTRA_COPILOT_COMMAND=copilot
YANTRA_COPILOT_TIMEOUT_S=120
YANTRA_PROVIDER_CHAIN=groq_primary,gemini_primary,groq_secondary,gemini_secondary,github_models
YANTRA_PROVIDER_MAX_ATTEMPTS=7
YANTRA_PROVIDER_MAX_REQUEST_TIME_MS=9000
YANTRA_PROVIDER_LANE_COOLDOWN_S=30
YANTRA_PROVIDER_REQUEST_TIMEOUT_S=4
YANTRA_GROQ_PRIMARY_MODEL=openai/gpt-oss-20b
YANTRA_GROQ_PRIMARY_API_KEY=
YANTRA_GEMINI_PRIMARY_MODEL=gemini-2.5-flash
YANTRA_GEMINI_PRIMARY_API_KEY=
YANTRA_GROQ_SECONDARY_MODEL=openai/gpt-oss-20b
YANTRA_GROQ_SECONDARY_API_KEY=
YANTRA_GEMINI_SECONDARY_MODEL=gemini-2.5-flash-lite
YANTRA_GEMINI_SECONDARY_API_KEY=
YANTRA_GITHUB_MODELS_MODEL=openai/gpt-4.1
YANTRA_GITHUB_MODELS_TOKEN=
YANTRA_AI_TARGET=local
YANTRA_AI_LOCAL_URL=http://127.0.0.1:8000
YANTRA_AI_RENDER_URL=https://yantra-ai.onrender.com
YANTRA_EMBEDDING_BACKEND=local
YANTRA_STARTUP_WARMUP=true
YANTRA_LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
YANTRA_LOCAL_EMBEDDING_DEVICE=cpu
YANTRA_LOCAL_EMBEDDING_TRUST_REMOTE_CODE=false
YANTRA_FAST_RESPONSES=true
YANTRA_RETRIEVAL_CACHE_TTL_S=180
YANTRA_RETRIEVAL_CACHE_MAX_ENTRIES=256
YANTRA_RESPONSE_CACHE_TTL_S=120
YANTRA_RESPONSE_CACHE_MAX_ENTRIES=256
YANTRA_AUTO_REINDEX=true
YANTRA_TOP_K=2
YANTRA_MIN_RETRIEVAL_SCORE=0.3
YANTRA_MIN_VECTOR_SCORE=0.35
YANTRA_VECTOR_INDEX_PATH=data/knowledge_index.json
